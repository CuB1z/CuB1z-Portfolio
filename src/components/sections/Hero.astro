---
import { t } from "i18n:astro";
import { socialData } from "@/constants/socialData";
import { MailIcon, GithubIcon, LinkedinIcon } from "@lucide/astro";
---

<section class="hero">
    <div class="hero-content">
        <div class="name-row">
            <h1 class="name">
                {t("hero:name")}<span class="dot">.</span>
            </h1>
        </div>

        <p class="role">{t("hero:role")}</p>

        <p class="role-meta">
            <span set:html={t("hero:meta_line_1")} />
            <br />
            <span set:html={t("hero:meta_line_2")} />
        </p>

        <div class="hero-contact">
            <a href={socialData.email}>
                <MailIcon size={14} class="ci" />
                <span>{socialData.email.replace("mailto:", "")}</span>
            </a>
            <a href={socialData.github} target="_blank" rel="noopener noreferrer">
                <GithubIcon size={14} class="ci" />
                <span>GitHub</span>
            </a>
            <a href={socialData.linkedin} target="_blank" rel="noopener noreferrer">
                <LinkedinIcon size={14} class="ci" />
                <span>LinkedIn</span>
            </a>
        </div>
    </div>

    <div class="hero-avatar" aria-hidden="true">
        <img
            src="https://avatars.githubusercontent.com/u/121297520?v=4"
            alt=""
            loading="eager"
        />
    </div>
</section>

<style>
    .hero {
        width: 100%;
        padding-top: 16px;
        margin-bottom: 72px;
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 48px;
        align-items: center;
    }

    .hero-content {
        min-width: 0;
    }

    .hero-avatar {
        width: 130px;
        height: 130px;
        border-radius: 9999px;
        overflow: hidden;
        flex-shrink: 0;
        margin-right: 24px;
    }

    .hero-avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .name-row {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 20px;
        align-items: baseline;
        margin-bottom: 32px;
    }

    .name {
        font-size: clamp(40px, 6vw, 60px);
        font-weight: 600;
        letter-spacing: -0.03em;
        line-height: 1;
        color: var(--ink);
    }

    .name .dot {
        color: var(--accent);
    }

    .role {
        font-size: clamp(19px, 2.3vw, 24px);
        color: var(--ink);
        font-weight: 500;
        letter-spacing: -0.015em;
        line-height: 1.35;
        margin-bottom: 16px;
    }

    .role-meta {
        font-size: 16px;
        color: var(--ink-soft);
        max-width: 56ch;
        line-height: 1.65;
    }

    .role-meta :global(strong) {
        color: var(--ink);
        font-weight: 600;
    }

    .hero-contact {
        display: flex;
        flex-wrap: wrap;
        gap: 12px 28px;
        margin-top: 32px;
        font-size: 15.5px;
        font-weight: 500;
    }

    .hero-contact a .ci {
        width: 16px;
        height: 16px;
    }

    .hero-contact a {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: var(--ink);
        transition: color 0.2s ease;
    }

    .hero-contact a:hover {
        color: var(--accent);
    }

    .hero-contact a .ci {
        color: var(--ink-mute);
        transition: color 0.2s ease;
        flex-shrink: 0;
    }

    .hero-contact a:hover .ci {
        color: var(--accent);
    }

    @media (max-width: 768px) {
        .hero {
            grid-template-columns: 1fr;
            gap: 28px;
        }
        .hero-avatar {
            order: -1;
            width: 96px;
            height: 96px;
        }
    }

    @media (max-width: 600px) {
        .hero {
            padding-top: 8px;
            margin-bottom: 48px;
        }
        .hero-contact {
            gap: 10px 20px;
            font-size: 13px;
        }
    }
</style>
