---
import { t } from "i18n:astro";
import { socialData } from "@/constants/socialData";
---

<header class="hero">
    <div class="shell">
        <span class="eyebrow">{t("hero:eyebrow")}</span>
        <h1>{t("hero:name_line1")}<br />{t("hero:name_line2")}</h1>
        <p class="bio" set:html={t("hero:bio")} />
        <div class="socials">
            <a href={socialData.email} aria-label="Email" title="Email">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2.5"/><path d="m22 7-9.4 5.5a1 1 0 0 1-1.2 0L2 7"/></svg>
            </a>
            <a href={socialData.github} target="_blank" rel="noopener noreferrer" aria-label="GitHub" title="GitHub">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 .5C5.37.5 0 5.78 0 12.29c0 5.2 3.44 9.6 8.21 11.16.6.11.82-.25.82-.56 0-.28-.01-1.02-.02-2-3.34.71-4.04-1.58-4.04-1.58-.55-1.37-1.34-1.74-1.34-1.74-1.09-.73.08-.72.08-.72 1.2.08 1.84 1.21 1.84 1.21 1.07 1.79 2.81 1.27 3.5.97.11-.76.42-1.27.76-1.56-2.67-.3-5.47-1.31-5.47-5.81 0-1.28.47-2.33 1.24-3.15-.13-.3-.54-1.52.12-3.16 0 0 1.01-.32 3.3 1.2.96-.26 1.98-.39 3-.4 1.02 0 2.04.14 3 .4 2.28-1.52 3.29-1.2 3.29-1.2.66 1.64.25 2.86.12 3.16.77.82 1.24 1.87 1.24 3.15 0 4.51-2.81 5.5-5.49 5.79.43.36.81 1.08.81 2.18 0 1.58-.01 2.85-.01 3.24 0 .31.21.68.83.56C20.57 21.88 24 17.48 24 12.29 24 5.78 18.63.5 12 .5z"/></svg>
            </a>
            <a href={socialData.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" title="LinkedIn">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.13 1.45-2.13 2.94v5.67H9.35V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.55C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.72C24 .77 23.2 0 22.22 0z"/></svg>
            </a>
        </div>
    </div>
</header>

<style>
    .hero {
        position: relative;
        z-index: 1;
        padding: 132px 0 68px;
    }
    .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        font-family: var(--font-mono);
        font-size: 12.5px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--accent);
        margin-bottom: 24px;
    }
    .eyebrow::before {
        content: "";
        width: 28px;
        height: 1px;
        background: var(--accent);
    }
    .hero h1 {
        font-size: clamp(48px, 9.5vw, 108px);
        font-weight: 800;
        letter-spacing: -0.045em;
        line-height: 0.92;
        color: var(--ink);
    }
    .bio {
        font-size: 17px;
        line-height: 1.7;
        color: var(--soft);
        max-width: 58ch;
        margin-top: 28px;
    }
    .bio :global(b) {
        color: var(--ink);
        font-weight: 600;
    }
    .socials {
        display: flex;
        gap: 12px;
        margin-top: 34px;
    }
    .socials a {
        width: 46px;
        height: 46px;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 1px solid var(--rule-2);
        color: var(--ink);
        background: var(--bg-card);
        transition: color 0.18s, border-color 0.18s, transform 0.18s;
    }
    .socials a:hover {
        border-color: var(--accent);
        color: var(--accent);
        transform: translateY(-3px);
    }
    .socials a svg {
        width: 20px;
        height: 20px;
    }
    @media (max-width: 600px) {
        .hero {
            padding: 116px 0 52px;
        }
    }
</style>
