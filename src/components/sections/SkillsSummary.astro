---
import { t } from "i18n:astro";
---

<section class="skills">
    <header class="section-head">
        <h2>
            {t("resume:skills_summary.heading")} <span class="em">{t("resume:skills_summary.headingEm")}</span>
        </h2>
    </header>

    <ul class="list">
        {
            t("resume:skills_summary.skills", {
                returnObjects: true,
            }).map((skill) => (
                <li>{skill}</li>
            ))
        }
    </ul>
</section>

<style>
    .skills {
        width: 100%;
        margin-bottom: 64px;
    }

    .section-head {
        padding-bottom: 28px;
        border-bottom: 1px solid var(--rule);
    }

    .section-head h2 {
        font-size: clamp(28px, 3.4vw, 36px);
        font-weight: 600;
        color: var(--ink);
        letter-spacing: -0.022em;
    }

    .section-head h2 .em {
        color: var(--accent);
    }

    .list {
        list-style: none;
        display: flex;
        flex-wrap: wrap;
        gap: 10px 12px;
        padding-top: 28px;
    }

    .list li {
        padding: 8px 16px;
        border: 1px solid var(--rule);
        border-radius: 999px;
        font-size: 13.5px;
        color: var(--ink-soft);
        cursor: default;
        user-select: none;
        transition: border-color 0.2s ease, color 0.2s ease;
    }

    .list li:hover {
        border-color: var(--accent);
        color: var(--accent);
    }
</style>
