---
import { t } from "i18n:astro";
import { buildUrl } from "@utils/urlUtils";

const links = [
    {
        slug: "projects",
        title: t("cardLinks:projects.title"),
        titleEm: t("cardLinks:projects.titleEm"),
        description: t("cardLinks:projects.description"),
    },
    {
        slug: "blog",
        title: t("cardLinks:blog.title"),
        titleEm: t("cardLinks:blog.titleEm"),
        description: t("cardLinks:blog.description"),
    },
    {
        slug: "resume",
        title: t("cardLinks:about.title"),
        titleEm: t("cardLinks:about.titleEm"),
        description: t("cardLinks:about.description"),
    },
];
---

<section class="destinations">
    {
        links.map((link, idx) => {
            const num = String(idx + 1).padStart(2, "0");
            return (
                <a class="dest" href={buildUrl(`/${link.slug}`)}>
                    <div class="head">
                        <h2 class="title">
                            <span class="num">{num}</span>
                            <span class="name">
                                {link.title}
                                {link.titleEm && (
                                    <>
                                        {" "}
                                        <span class="em">{link.titleEm}</span>
                                    </>
                                )}
                            </span>
                        </h2>
                        <span class="arrow" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
                                <path d="M7 17 17 7M9 7h8v8"/>
                            </svg>
                        </span>
                    </div>
                    <p class="blurb">{link.description}</p>
                </a>
            );
        })
    }
</section>

<style>
    .destinations {
        width: 100%;
        display: flex;
        flex-direction: column;
        border-top: 1px solid var(--rule);
    }

    .dest {
        display: flex;
        flex-direction: column;
        gap: 10px;
        padding: 32px 0;
        border-bottom: 1px solid var(--rule);
        color: var(--ink);
        transition: padding-left 0.3s cubic-bezier(0.2, 0.7, 0.2, 1);
    }

    .dest:hover {
        padding-left: 14px;
    }

    .head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
    }

    .title {
        display: inline-flex;
        align-items: baseline;
        gap: 16px;
        font-size: clamp(20px, 2.4vw, 26px);
        font-weight: 600;
        color: var(--ink);
        letter-spacing: -0.02em;
        transition: color 0.2s ease;
        min-width: 0;
    }

    .title .num {
        color: var(--ink-mute);
        flex-shrink: 0;
    }

    .title .em {
        color: var(--accent);
    }

    .dest:hover .title {
        color: var(--accent);
    }

    .blurb {
        font-size: 15.5px;
        color: var(--ink-soft);
        line-height: 1.65;
        max-width: 60ch;
    }

    .arrow {
        display: inline-flex;
        color: var(--ink-mute);
        transition: color 0.2s ease, transform 0.3s ease;
        flex-shrink: 0;
    }

    .dest:hover .arrow {
        color: var(--accent);
        transform: translate(5px, -5px);
    }

    @media (max-width: 600px) {
        .dest {
            padding: 24px 0;
            gap: 8px;
        }
    }
</style>
