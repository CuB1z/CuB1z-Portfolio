---
import { t, getLocale } from "i18n:astro";
import { buildUrl } from "@/utils/urlUtils";
import Carousel from "@components/shared/Carousel.astro";
import SectionHeader from "@components/shared/SectionHeader.astro";

interface Props {
    num: string;
}
const { num } = Astro.props as Props;

interface Project {
    id: string;
    title: string;
    featured?: boolean;
    page?: string;
    flag?: string;
    image?: string;
    description: string;
    techStack: string[];
    links: { github: string | null; live: string | null };
}

const heading = t("projects:heading");
const projects = t("projects:projects", { returnObjects: true }) as Project[];

const featured = projects.find((p) => p.featured) ?? projects[0];
const rest = projects.filter((p) => p !== featured);

// Featured card links to its internal case-study page when one exists,
// otherwise straight to the live demo.
const featuredHref = featured.page
    ? buildUrl(featured.page)
    : featured.links.live;
const featuredExternal = !featured.page;

const previewHost = featured.links.live
    ? new URL(featured.links.live).host
    : null;

// Machine-readable list of the projects so AI can read each one even though
// they don't all have a dedicated page.
const locale = getLocale();
const projectsLd = {
    "@context": "https://schema.org",
    "@type": "ItemList",
    name: heading,
    itemListElement: projects.map((p, i) => {
        const sameAs = [p.links.live, p.links.github].filter(Boolean);
        const url = p.page
            ? new URL(`${p.page}/`, Astro.site).toString()
            : (p.links.live ?? p.links.github);
        return {
            "@type": "ListItem",
            position: i + 1,
            item: {
                "@type": "CreativeWork",
                name: p.title,
                description: p.description,
                inLanguage: locale,
                ...(url ? { url } : {}),
                ...(sameAs.length ? { sameAs } : {}),
                keywords: p.techStack.join(", "),
            },
        };
    }),
};
---

<section id="work" class="section">
    <script
        type="application/ld+json"
        set:html={JSON.stringify(projectsLd)}
    />
    <div class="shell">
        <SectionHeader num={num} heading={heading} />

        <article class="feat-wide">
            {featuredHref && (
                <a
                    class="card-cover"
                    href={featuredHref}
                    aria-label={featured.title}
                    {...(featuredExternal
                        ? { target: "_blank", rel: "noopener noreferrer" }
                        : {})}
                />
            )}
            <div class="info">
                {featured.flag && (
                    <span class="flag">
                        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 17.27 18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                        {featured.flag}
                    </span>
                )}
                <h3>{featured.title}</h3>
                <p>{featured.description}</p>
                <div class="tags">{featured.techStack.map((tech) => <span>{tech}</span>)}</div>
            </div>
            <div class="preview">
                {featured.image ? (
                    <img src={featured.image} alt={featured.title} loading="lazy" />
                ) : (
                    previewHost && <span>{previewHost}</span>
                )}
            </div>
        </article>

        <Carousel cols={2} label="projects">
            {
                rest.map((project) => {
                    const href = project.links.live ?? project.links.github;
                    const Tag = href ? "a" : "div";
                    return (
                        <Tag
                            class="card"
                            href={href ?? undefined}
                            target={href ? "_blank" : undefined}
                            rel={href ? "noopener noreferrer" : undefined}
                        >
                            <h3>
                                {project.title}
                                {href && <span class="ar"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17 17 7M9 7h8v8"/></svg></span>}
                            </h3>
                            <p>{project.description}</p>
                            <div class="tags">
                                {project.techStack.map((tech) => (
                                    <span>{tech}</span>
                                ))}
                            </div>
                        </Tag>
                    );
                })
            }
        </Carousel>
    </div>
</section>

<style>
    .feat-wide {
        display: grid;
        grid-template-columns: 1.05fr 1fr;
        gap: 40px;
        align-items: stretch;
        position: relative;
        border: 1px solid var(--rule-2);
        border-radius: 22px;
        padding: 38px;
        background: linear-gradient(150deg, var(--bg-card-2), var(--bg-card));
        overflow: hidden;
        margin-bottom: 16px;
        transition: border-color 0.2s;
    }
    .feat-wide:hover {
        border-color: var(--accent);
    }
    .feat-wide::after {
        content: "";
        position: absolute;
        top: -40%;
        right: -8%;
        width: 420px;
        height: 420px;
        background: radial-gradient(circle, var(--accent-glow), transparent 65%);
        pointer-events: none;
        z-index: -1;
    }
    .card-cover {
        position: absolute;
        inset: 0;
        z-index: 1;
        border-radius: 22px;
    }
    .info {
        position: relative;
    }
    .flag {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-family: var(--font-mono);
        font-size: 11px;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--accent);
        border: 1px solid var(--accent-dim);
        background: var(--accent-dim);
        border-radius: 999px;
        padding: 5px 12px;
    }
    .flag svg {
        width: 11px;
        height: 11px;
        flex-shrink: 0;
    }
    .feat-wide h3 {
        font-size: clamp(30px, 4vw, 42px);
        font-weight: 800;
        letter-spacing: -0.03em;
        margin: 16px 0 0;
        transition: color 0.2s;
    }
    .feat-wide:hover h3 {
        color: var(--accent);
    }
    .feat-wide p {
        font-size: 15.5px;
        line-height: 1.7;
        margin-top: 16px;
        max-width: 48ch;
    }
    .feat-wide .tags {
        margin-top: 16px;
    }
    .preview {
        position: relative;
        overflow: hidden;
        min-height: 240px;
        border-radius: 14px;
        border: 1px solid var(--rule-2);
        background:
            linear-gradient(135deg, rgba(115, 179, 216, 0.18), rgba(115, 179, 216, 0.02)),
            repeating-linear-gradient(45deg, transparent, transparent 11px, rgba(255, 255, 255, 0.02) 11px, rgba(255, 255, 255, 0.02) 22px);
        display: flex;
        align-items: flex-end;
        padding: 14px;
    }
    .preview img {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }
    .preview span {
        font-family: var(--font-mono);
        font-size: 11.5px;
        color: var(--soft);
    }
    .card {
        border: 1px solid var(--rule);
        border-radius: 16px;
        padding: 24px;
        background: var(--bg-card);
        transition: border-color 0.2s, transform 0.2s;
        display: flex;
        flex-direction: column;
    }
    .card:hover {
        border-color: var(--accent);
        transform: translateY(-4px);
    }
    .card h3 {
        font-size: 20px;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
    .card h3 .ar {
        color: var(--mute);
        display: inline-flex;
        transition: color 0.2s, transform 0.2s;
    }
    .card h3 .ar svg {
        width: 18px;
        height: 18px;
    }
    .card:hover h3 .ar {
        color: var(--accent);
        transform: translate(4px, -4px);
    }
    .card p {
        font-size: 14.5px;
        line-height: 1.6;
        margin-top: 11px;
        flex: 1;
    }
    .card .tags {
        margin-top: 16px;
    }

    @media (max-width: 880px) {
        .feat-wide {
            grid-template-columns: 1fr;
            gap: 26px;
            padding: 28px;
            margin-bottom: 36px;
        }
        .preview {
            display: none;
        }
    }

    @media (max-width: 760px) {
        .card:hover {
            transform: none;
        }
    }
</style>
