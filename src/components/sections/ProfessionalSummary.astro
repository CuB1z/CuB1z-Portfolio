---
import { t } from "i18n:astro";
import { socialData } from "@/constants/socialData";

import { MailIcon, MapPinIcon } from "@lucide/astro";
import SocialLinks from "@components/sections/SocialLinks.astro";

const info = {
    email: {
        value: socialData.email.replace("mailto:", ""),
        icon: MailIcon,
    },
    place: {
        value: t("resume:professional_summary.place"),
        icon: MapPinIcon,
    },
};
---

<section>
    <header>
        <div class="text">
            <h2>{t("resume:professional_summary.title")}</h2>
            <p class="subtitle">{t("resume:professional_summary.subtitle")}</p>
            <div class="info">
                <div class="info-item">
                    <info.email.icon size={14} class="icon" />
                    <span>{info.email.value}</span>
                </div>
                <span class="dot">•</span>
                <div class="info-item place">
                    <info.place.icon size={14} class="icon" />
                    <span>{info.place.value}</span>
                </div>
            </div>
        </div>
    </header>
    <div class="resume-content">
        {
            t("resume:professional_summary.summary", {
                returnObjects: true,
            }).map((paragraph) => <p>{paragraph}</p>)
        }
    </div>
    <SocialLinks align="right" />
</section>

<style>
    section {
        width: 100%;
        padding: 24px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        margin-bottom: 48px;
        border-radius: 8px;
        background-color: var(--bg-secondary);
        background-image: radial-gradient(
            circle at 90% 50%,
            var(--aureola-big) 100px,
            transparent 4px
        );
        border: 1px solid var(--border-color);

        header {
            width: 100%;
            margin-bottom: 32px;

            h2 {
                color: var(--text-primary);
                margin-bottom: 8px;
            }

            .subtitle {
                color: var(--accent-light);
                font-weight: 500;
                letter-spacing: 0.5px;
                margin-bottom: 20px;
            }
        }

        .info {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            gap: 12px;
            color: var(--text-secondary);
            font-size: 14px;
            font-weight: 500;
            letter-spacing: 0.5px;

            .info-item {
                display: flex;
                align-items: center;
                color: var(--text-secondary);

                .icon {
                    margin-right: 8px;
                }
            }

            .dot {
                color: var(--accent);
            }
        }

        .resume-content {
            width: 100%;
            display: flex;
            flex-direction: column;
            gap: 16px;
            color: var(--text-secondary);
            font-size: 16px;
            line-height: 1.6;
            margin-bottom: 32px;
        }
    }
</style>
