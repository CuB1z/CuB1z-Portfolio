---
import { t } from "i18n:astro";
import { socialData } from "@/constants/socialData";
import { MailIcon, MapPinIcon, GithubIcon, LinkedinIcon } from "@lucide/astro";
---

<section class="prof">
    <header class="page-head">
        <h1>
            {t("resume:professional_summary.title")}<span class="dot">.</span>
        </h1>
        <p class="subtitle">{t("resume:professional_summary.subtitle")}</p>

        <div class="contact">
            <a href={socialData.email}>
                <MailIcon size={14} class="ci" />
                <span>{socialData.email.replace("mailto:", "")}</span>
            </a>
            <span class="contact-item">
                <MapPinIcon size={14} class="ci" />
                <span>{t("resume:professional_summary.place")}</span>
            </span>
            <a href={socialData.github} target="_blank" rel="noopener noreferrer">
                <GithubIcon size={14} class="ci" />
                <span>GitHub</span>
            </a>
            <a href={socialData.linkedin} target="_blank" rel="noopener noreferrer">
                <LinkedinIcon size={14} class="ci" />
                <span>LinkedIn</span>
            </a>
        </div>
    </header>

    <div class="summary">
        {
            t("resume:professional_summary.summary", {
                returnObjects: true,
            }).map((paragraph) => <p>{paragraph}</p>)
        }
    </div>
</section>

<style>
    .prof {
        width: 100%;
        margin-bottom: 64px;
    }

    .page-head {
        padding-bottom: 48px;
        margin-bottom: 40px;
        border-bottom: 1px solid var(--rule);
    }

    .eyebrow {
        font-size: 11.5px;
        font-weight: 500;
        color: var(--ink-mute);
        letter-spacing: 0.12em;
        text-transform: uppercase;
        margin-bottom: 20px;
    }

    .page-head h1 {
        font-size: clamp(36px, 5vw, 52px);
        font-weight: 600;
        letter-spacing: -0.025em;
        color: var(--ink);
        margin-bottom: 12px;
    }

    .page-head h1 .dot {
        color: var(--accent);
    }

    .subtitle {
        font-size: clamp(17px, 2vw, 20px);
        color: var(--ink-soft);
        font-weight: 500;
        margin-bottom: 32px;
    }

    .contact {
        display: flex;
        flex-wrap: wrap;
        gap: 12px 28px;
        font-size: 14px;
    }

    .contact > * {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: var(--ink);
        transition: color 0.2s ease;
    }

    .contact a:hover {
        color: var(--accent);
    }

    .contact .ci {
        color: var(--ink-mute);
        flex-shrink: 0;
        transition: color 0.2s ease;
    }

    .contact a:hover .ci {
        color: var(--accent);
    }

    .contact-item {
        color: var(--ink-soft);
    }

    .summary {
        display: flex;
        flex-direction: column;
        gap: 20px;
        font-size: 16.5px;
        color: var(--ink-soft);
        line-height: 1.75;
    }
</style>
