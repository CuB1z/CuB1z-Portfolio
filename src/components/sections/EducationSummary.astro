---
import { t } from "i18n:astro";

const studies = t("resume:education_summary.education_details", {
    returnObjects: true,
}) as Array<{
    institution: string;
    degree: string;
    duration: string;
    description: string;
}>;

const splitDuration = (duration: string) => {
    const [start, ...rest] = duration.split(/\s*[-–—]\s*/);
    return { start: start.trim(), end: rest.length ? rest.join(" - ").trim() : null };
};
---

<section class="edu">
    <header class="section-head">
        <p class="lbl">{t("resume:education_summary.label")}</p>
        <h2>
            {t("resume:education_summary.heading")} <span class="em">{t("resume:education_summary.headingEm")}</span>
        </h2>
    </header>

    <ul class="list">
        {
            studies.map((edu) => {
                const { start, end } = splitDuration(edu.duration);
                return (
                    <li class="entry">
                        <div class="body">
                            <h3 class="degree">{edu.degree}</h3>
                            <p class="institution">{edu.institution}</p>
                            <p class="desc">{edu.description}</p>
                        </div>
                        <div class="when">
                            <span class="when-date">{start}</span>
                            {end && <span class="when-date when-end">{end}</span>}
                        </div>
                    </li>
                );
            })
        }
    </ul>
</section>

<style>
    .edu {
        width: 100%;
        margin-bottom: 64px;
    }

    .section-head {
        padding-bottom: 28px;
        border-bottom: 1px solid var(--rule);
    }

    .lbl {
        font-size: 11.5px;
        font-weight: 500;
        color: var(--ink-mute);
        letter-spacing: 0.12em;
        text-transform: uppercase;
        margin-bottom: 16px;
    }

    .section-head h2 {
        font-size: clamp(28px, 3.4vw, 36px);
        font-weight: 600;
        color: var(--ink);
        letter-spacing: -0.022em;
    }

    .section-head h2 .em {
        color: var(--accent);
    }

    .list {
        list-style: none;
        display: flex;
        flex-direction: column;
    }

    .entry {
        display: grid;
        grid-template-columns: 1fr 140px;
        gap: 32px;
        padding: 28px 0;
        border-bottom: 1px solid var(--rule);
    }

    .entry:last-child {
        border-bottom: none;
    }

    .when {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 6px;
        padding-top: 10px;
    }

    .when-date {
        font-size: 12px;
        font-weight: 500;
        color: var(--ink-mute);
        letter-spacing: 0.1em;
        text-transform: uppercase;
        line-height: 1.2;
    }


    .body {
        display: flex;
        flex-direction: column;
        gap: 10px;
        min-width: 0;
    }

    .degree {
        font-size: clamp(20px, 2.2vw, 24px);
        font-weight: 600;
        color: var(--ink);
        letter-spacing: -0.02em;
    }

    .institution {
        font-size: 15px;
        color: var(--accent);
        font-weight: 500;
        margin-bottom: 6px;
    }

    .desc {
        font-size: 15.5px;
        color: var(--ink-soft);
        line-height: 1.7;
        max-width: 64ch;
    }

    @media (max-width: 600px) {
        .entry {
            grid-template-columns: 1fr;
            gap: 12px;
            padding: 32px 0;
        }
        .when {
            order: -1;
            flex-direction: row;
            align-items: center;
            gap: 8px;
            padding-top: 0;
        }
        .when-end::before {
            content: "—";
            margin-right: 8px;
            opacity: 0.6;
        }
    }
</style>
