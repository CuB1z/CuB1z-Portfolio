---
import { GithubIcon } from "@lucide/astro";
import { t } from "i18n:astro";
---

<section class="projects">
    <header class="page-head">
        <h1>
            {t("projects:heading")} <span class="em">{t("projects:headingEm")}</span>
        </h1>
        <p class="lede">{t("projects:lede")}</p>
    </header>

    <ul class="project-list">
        {
            t("projects:projects", { returnObjects: true }).map((project, idx) => {
                const num = String(idx + 1).padStart(2, "0");
                return (
                    <li class="project">
                        {project.links.live ? (
                            <a
                                class="title"
                                href={project.links.live}
                                target="_blank"
                                rel="noopener noreferrer"
                            >
                                <span class="num">{num}</span>
                                <span class="name">{project.title}</span>
                                <svg
                                    class="arrow"
                                    viewBox="0 0 24 24"
                                    width="18"
                                    height="18"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="1.7"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    aria-hidden="true"
                                >
                                    <path d="M7 17 17 7M9 7h8v8" />
                                </svg>
                            </a>
                        ) : (
                            <h3 class="title title-static">
                                <span class="num">{num}</span>
                                <span class="name">{project.title}</span>
                            </h3>
                        )}

                        <p class="desc">{project.description}</p>

                        <div class="footer">
                            <p class="peek">
                                {project.techStack.map((tech, i) => (
                                    <>
                                        {i > 0 && <span class="sep">·</span>}
                                        <span class="tag">{tech}</span>
                                    </>
                                ))}
                            </p>

                            {project.links.github && (
                                <a
                                    class="gh"
                                    href={project.links.github}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    title="GitHub"
                                    aria-label={`${project.title} on GitHub`}
                                >
                                    <GithubIcon size={22} />
                                </a>
                            )}
                        </div>
                    </li>
                );
            })
        }
    </ul>
</section>

<style>
    .projects {
        width: 100%;
    }

    .page-head {
        padding-bottom: 40px;
        border-bottom: 1px solid var(--rule);
    }

    .page-head h1 {
        font-size: clamp(32px, 4.5vw, 44px);
        font-weight: 600;
        letter-spacing: -0.025em;
        color: var(--ink);
        margin-bottom: 16px;
    }

    .page-head h1 .em {
        color: var(--accent);
    }

    .lede {
        font-size: 16px;
        color: var(--ink-soft);
        max-width: 60ch;
        line-height: 1.65;
    }

    .project-list {
        list-style: none;
        display: flex;
        flex-direction: column;
    }

    .project {
        display: flex;
        flex-direction: column;
        gap: 16px;
        padding: 36px 0;
        border-bottom: 1px solid var(--rule);
    }

    .title {
        display: inline-flex;
        align-items: baseline;
        gap: 16px;
        font-size: clamp(20px, 2.4vw, 26px);
        font-weight: 600;
        color: var(--ink);
        letter-spacing: -0.02em;
        width: max-content;
        max-width: 100%;
        transition: color 0.2s ease, gap 0.2s ease;
    }

    .title .num {
        font-size: inherit;
        font-weight: inherit;
        color: var(--ink-mute);
        letter-spacing: -0.02em;
        flex-shrink: 0;
    }

    .title .arrow {
        color: var(--ink-mute);
        transition: color 0.2s ease, transform 0.3s ease;
        flex-shrink: 0;
        align-self: center;
    }

    a.title:hover {
        color: var(--accent);
    }

    a.title:hover .arrow {
        color: var(--accent);
        transform: translate(4px, -4px);
    }

    .desc {
        font-size: 15.5px;
        color: var(--ink-soft);
        line-height: 1.7;
        max-width: 64ch;
    }

    .footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
        margin-top: 4px;
    }

    .peek {
        font-size: 12.5px;
        color: var(--ink-mute);
        flex: 1;
        min-width: 0;
    }

    .peek .tag {
        color: var(--ink-soft);
        text-decoration: underline;
        text-decoration-color: var(--rule-strong);
        text-underline-offset: 6px;
        text-decoration-thickness: 1px;
    }

    .peek .sep {
        display: inline-block;
        margin: 0 12px;
        color: var(--ink-mute);
        opacity: 0.5;
    }

    .gh {
        display: inline-flex;
        color: var(--ink-mute);
        transition: color 0.2s ease, transform 0.2s ease;
        flex-shrink: 0;
    }

    .gh:hover {
        color: var(--accent);
        transform: translateY(-2px);
    }

    @media (max-width: 600px) {
        .project {
            padding: 32px 0;
            gap: 14px;
        }
        .footer {
            flex-wrap: wrap;
            gap: 16px;
        }
    }
</style>
