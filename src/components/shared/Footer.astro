---
const year = new Date().getFullYear();
---

<footer class="foot">
    <span>© {year}&nbsp;&nbsp;&nbsp;Madrid</span>
</footer>

<style>
    .foot {
        width: 100%;
        margin-top: 64px;
        padding: 24px 0 0;
        display: flex;
        justify-content: center;
        align-items: center;
        font-size: 13px;
        color: var(--ink-mute);
        letter-spacing: 0.04em;
    }

    @media (max-width: 600px) {
        .foot {
            margin-top: 48px;
        }
    }
</style>
