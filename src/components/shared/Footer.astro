---
import { t } from "i18n:astro";
import { socialData } from "@/constants/socialData";

const year = new Date().getFullYear();
---

<footer class="foot">
    <div class="shell foot-bar">
        <span class="copy">© {year} {t("common:footer_rights")}</span>
        <div class="foot-links">
            <a href={socialData.github} target="_blank" rel="noopener noreferrer">GitHub</a>
            <a href={socialData.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn</a>
            <a href={socialData.email}>Email</a>
        </div>
    </div>
</footer>

<style>
    .foot {
        position: relative;
        z-index: 1;
        margin-top: 24px;
        padding: 36px 0;
        border-top: 1px solid var(--rule);
    }
    .foot-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 18px;
        flex-wrap: wrap;
    }
    .copy {
        font-family: var(--font-mono);
        font-size: 12px;
        color: var(--mute);
    }
    .foot-links {
        display: flex;
        gap: 18px;
        font-size: 13px;
        font-weight: 500;
    }
    .foot-links a {
        color: var(--soft);
        transition: color 0.18s;
    }
    .foot-links a:hover {
        color: var(--accent);
    }
    @media (max-width: 480px) {
        .foot-bar {
            flex-direction: column;
            align-items: center;
            text-align: center;
            gap: 14px;
        }
    }
</style>
