---
import { getLocale } from "i18n:astro";

interface Props {
    altLangUrl?: string;
}

const { altLangUrl } = Astro.props as Props;

const locale = getLocale();
const currentPath = Astro.url.pathname;
const cleanPath = currentPath.replace(/^\/es/, "") || "/";

const enPath = locale === "en" ? currentPath : (altLangUrl ?? cleanPath);
const esPath = locale === "es" ? currentPath : (altLangUrl ?? `/es${cleanPath === "/" ? "" : cleanPath}`);
---

<div class="lang">
    <a
        class:list={["item", { active: locale === "en" }]}
        href={enPath}
        aria-current={locale === "en" ? "page" : undefined}
        title="Switch to EN"
    >
        EN
    </a>
    <span class="sep">/</span>
    <a
        class:list={["item", { active: locale === "es" }]}
        href={esPath}
        aria-current={locale === "es" ? "page" : undefined}
        title="Switch to ES"
    >
        ES
    </a>
</div>

<style>
    .lang {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 13px;
        font-weight: 500;
        letter-spacing: 0.02em;
    }

    .item {
        color: var(--ink-mute);
        transition: color 0.2s ease;
    }

    .item.active {
        color: var(--ink);
    }

    .item:not(.active):hover {
        color: var(--accent);
    }

    .sep {
        color: var(--ink-mute);
        font-weight: 400;
    }
</style>
