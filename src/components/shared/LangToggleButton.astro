---
import { getLocale } from "i18n:astro";

interface Props {
    altLangUrl?: string;
}

const { altLangUrl } = Astro.props as Props;

const locale = getLocale();
const currentPath = Astro.url.pathname;

const targetPath =
    locale === "en"
        ? `/es${currentPath}`
        : currentPath.replace(/^\/es/, "") || "/";

const currentLang = locale === "en" ? "EN" : "ES";
const otherLang = locale === "en" ? "ES" : "EN";
---

<a class="lang" href={altLangUrl || targetPath} title={`Switch to ${otherLang}`}>
    <span class="current">{currentLang}</span>
    <span class="sep">/</span>
    <span class="other">{otherLang}</span>
</a>

<style>
    .lang {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 13px;
        font-weight: 500;
        color: var(--ink);
        letter-spacing: 0.02em;
    }

    .lang .current {
        color: var(--ink);
    }

    .lang .sep {
        color: var(--ink-mute);
        font-weight: 400;
    }

    .lang .other {
        color: var(--ink-mute);
        transition: color 0.2s ease;
    }

    .lang:hover {
        color: var(--ink);
    }

    .lang:hover .other {
        color: var(--accent);
    }
</style>
