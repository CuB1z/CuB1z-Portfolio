---
interface Props {
    variant: "primary";
    title?: string;
    href?: string;
}

const { variant, title, href } = Astro.props as Props;
---

{
    href ? (
        <a class={`button ${variant}`} href={href} title={title}>
            <slot />
        </a>
    ) : (
        <button class={`button ${variant}`} title={title}>
            <slot />
        </button>
    )
}

<style>
    .button {
        width: max-content;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 10px 18px;
        gap: 8px;
        border: 1px solid var(--rule);
        background: transparent;
        font-size: 13px;
        font-weight: 500;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--ink);
        border-radius: 999px;
        cursor: pointer;
        transition: border-color 0.2s ease, color 0.2s ease, gap 0.2s ease;
    }

    .button:hover {
        border-color: var(--accent);
        color: var(--accent);
        gap: 12px;
    }

    .button:active {
        transform: scale(0.97);
    }
</style>
