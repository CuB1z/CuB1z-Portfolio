---
// Reusable, self-contained carousel: a responsive grid on desktop that becomes
// a swipeable, snap-scrolling carousel with dots + arrows on mobile. Slides go
// in the default slot. Everything the carousel needs (markup, styles and
// behaviour) lives in this file. Dots are generated by the script below, one
// per slide, so the count always matches.
import ArrowButton from "@components/shared/ArrowButton.astro";

interface Props {
    cols?: number; // desktop columns
    label?: string; // accessible label for the arrows
    class?: string;
}

const { cols = 3, label = "items", class: extra = "" } = Astro.props as Props;
---

<div
    class:list={["carousel", extra]}
    data-carousel
    style={`--car-cols:${cols}`}
>
    <div class="car-track" data-car-track>
        <slot />
    </div>
    <div class="car-ctrl">
        <div class="car-dots"></div>
        <div class="car-arrows">
            <ArrowButton dir="prev" label={`Previous ${label}`} />
            <ArrowButton dir="next" label={`Next ${label}`} />
        </div>
    </div>
</div>

<style>
    .car-track {
        display: grid;
        grid-template-columns: repeat(var(--car-cols, 3), 1fr);
        gap: 16px;
    }

    /* controls — hidden until the track becomes a carousel on mobile */
    .car-ctrl {
        display: none;
        align-items: center;
        justify-content: space-between;
        margin-top: 24px;
    }
    .car-dots {
        display: flex;
        align-items: center;
        gap: 8px;
    }
    /* dots are created in the script, so they live outside this component's
       scope — style them globally (scoped under the local .car-dots). */
    .car-dots :global(.car-dot) {
        width: 8px;
        height: 8px;
        padding: 0;
        border: 0;
        border-radius: 50%;
        background: var(--rule-2);
        cursor: pointer;
        transition: background 0.18s, transform 0.18s;
    }
    .car-dots :global(.car-dot.active) {
        background: var(--accent);
        transform: scale(1.15);
    }
    .car-arrows {
        display: flex;
        gap: 7px;
    }

    @media (max-width: 760px) {
        .car-track {
            display: flex;
            gap: 14px;
            overflow-x: auto;
            scroll-snap-type: x mandatory;
            -webkit-overflow-scrolling: touch;
            scrollbar-width: none;
            padding-bottom: 2px;
        }
        .car-track::-webkit-scrollbar {
            display: none;
        }
        .car-track > :global(*) {
            flex: 0 0 100%;
            scroll-snap-align: start;
        }
        .car-ctrl {
            display: flex;
        }
    }
</style>

<script>
    // Drives every <Carousel> on the page. Bundled once even if the component
    // is used multiple times; re-runs on each view-transition navigation.
    function initCarousels() {
        const roots = Array.from(
            document.querySelectorAll<HTMLElement>("[data-carousel]")
        );
        roots.forEach((root) => {
            const track = root.querySelector<HTMLElement>("[data-car-track]");
            const ctrl = root.querySelector<HTMLElement>(".car-ctrl");
            if (!track || !ctrl) return;
            const slides = Array.from(track.children).filter(
                (n): n is HTMLElement => n instanceof HTMLElement
            );
            if (!slides.length) return;

            // One dot per slide.
            const dotsBox = ctrl.querySelector<HTMLElement>(".car-dots");
            if (dotsBox) {
                dotsBox.innerHTML = "";
                slides.forEach((_, i) => {
                    const b = document.createElement("button");
                    b.type = "button";
                    b.className = "car-dot";
                    b.setAttribute("aria-label", `Go to item ${i + 1}`);
                    dotsBox.appendChild(b);
                });
            }
            const dots = dotsBox
                ? Array.from(dotsBox.querySelectorAll<HTMLButtonElement>(".car-dot"))
                : [];
            const prev = ctrl.querySelector<HTMLButtonElement>('[data-rel="prev"]');
            const next = ctrl.querySelector<HTMLButtonElement>('[data-rel="next"]');

            // Distance between slides (covers any gap).
            const step = () => {
                if (slides.length > 1) {
                    const d =
                        slides[1].getBoundingClientRect().left -
                        slides[0].getBoundingClientRect().left;
                    if (d > 0) return d;
                }
                return slides[0].getBoundingClientRect().width || 1;
            };
            const current = () => Math.round(track.scrollLeft / step());
            const go = (i: number) => {
                const n = ((i % slides.length) + slides.length) % slides.length;
                track.scrollTo({ left: n * step(), behavior: "smooth" });
            };
            const update = () => {
                const idx = current();
                dots.forEach((d, i) => d.classList.toggle("active", i === idx));
            };
            dots.forEach((d, i) => (d.onclick = () => go(i)));
            if (prev) prev.onclick = () => go(current() - 1);
            if (next) next.onclick = () => go(current() + 1);
            track.addEventListener("scroll", update, { passive: true });
            update();
        });
    }

    document.addEventListener("astro:page-load", initCarousels);
</script>
