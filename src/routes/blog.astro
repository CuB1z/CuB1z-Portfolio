---
import { getLocale, t } from "i18n:astro";
import { getCollection } from "astro:content";

import { buildUrl } from "@/utils/urlUtils";
import Layout from "@layouts/Layout.astro";
import Breadcrumb from "@components/shared/Breadcrumb.astro";
import ArrowButton from "@components/shared/ArrowButton.astro";

const locale = getLocale();

const allPosts = await getCollection("post");
const posts = allPosts
    .filter((post) => (post.data.locale ?? "en") === locale)
    .sort(
        (a, b) =>
            new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
    );

const fmt = (date: Date) =>
    new Date(date).toLocaleDateString(locale === "es" ? "es-ES" : "en-US", {
        month: "short",
        year: "numeric",
    });

const PER_PAGE = 4;
const pageCount = Math.ceil(posts.length / PER_PAGE);
---

<Layout navActive="writing" title={`${t("blog:heading")} · Diego Sánchez Rincón`}>
    <div class="blog-wrap">
        <div class="shell">
            <div class="crumbs-top">
                <Breadcrumb
                    items={[
                        { label: locale === "es" ? "Inicio" : "Home", href: buildUrl("/") },
                        { label: t("blog:heading") },
                    ]}
                />
            </div>
            <header class="page-head">
                <h1>{t("blog:heading")}</h1>
            </header>

            <div class="list">
                {
                    posts.map((post) => (
                        <a class="post" href={buildUrl(`/blog/${post.data.slug || post.slug}`)}>
                            <span class="date">{fmt(post.data.pubDate)}</span>
                            <h2>
                                {post.data.title}
                                <span class="ar">
                                    <svg viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M7 17 17 7M9 7h8v8" />
                                    </svg>
                                </span>
                            </h2>
                            <p class="excerpt">{post.data.description}</p>
                            {post.data.tags && (
                                <div class="tags">
                                    {post.data.tags.slice(0, 4).map((tag) => (
                                        <span>{tag}</span>
                                    ))}
                                </div>
                            )}
                        </a>
                    ))
                }
            </div>

            {
                pageCount > 1 && (
                    <nav class="pager" aria-label="Pagination" hidden>
                        <ArrowButton dir="prev" label="Previous page" />
                        <div class="pg-nums">
                            {Array.from({ length: pageCount }).map((_, i) => (
                                <button type="button" class="pg-num" data-page={i + 1}>{i + 1}</button>
                            ))}
                        </div>
                        <ArrowButton dir="next" label="Next page" />
                    </nav>
                )
            }
        </div>
    </div>
</Layout>

<style>
    .blog-wrap {
        position: relative;
        z-index: 1;
        padding: 124px 0 72px;
    }
    .crumbs-top {
        margin-bottom: 24px;
    }
    .page-head h1 {
        font-size: clamp(40px, 7vw, 68px);
        font-weight: 800;
        letter-spacing: -0.04em;
        line-height: 1;
        color: var(--ink);
    }
    .list {
        margin-top: 36px;
        display: flex;
        flex-direction: column;
    }
    .post {
        display: block;
        padding: 32px 0;
        border-top: 1px solid var(--rule);
        transition: padding-left 0.25s cubic-bezier(0.2, 0.7, 0.2, 1);
    }
    .post:first-child {
        border-top: 0;
    }
    @media (hover: hover) {
        .post:hover {
            padding-left: 14px;
        }
    }
    .post .date {
        display: block;
        font-family: var(--font-mono);
        font-size: 11.5px;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--mute);
        margin-bottom: 12px;
    }
    .post h2 {
        font-size: clamp(21px, 2.3vw, 27px);
        font-weight: 700;
        letter-spacing: -0.022em;
        color: var(--ink);
        line-height: 1.25;
        max-width: 30ch;
        transition: color 0.18s;
    }
    .post:hover h2 {
        color: var(--accent);
    }
    .post h2 .ar {
        display: inline-flex;
        vertical-align: -2px;
        color: var(--mute);
        margin-left: 8px;
        transition: color 0.18s, transform 0.25s;
    }
    .post:hover h2 .ar {
        color: var(--accent);
        transform: translate(3px, -3px);
    }
    .post .excerpt {
        margin-top: 12px;
        font-size: 15.5px;
        line-height: 1.65;
        color: var(--soft);
        max-width: 64ch;
    }
    .post .tags {
        margin-top: 16px;
    }

    .pager {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 7px;
        margin-top: 52px;
    }
    .pg-nums {
        display: flex;
        gap: 7px;
    }
    .pager button {
        font-family: var(--font-mono);
        font-size: 13px;
        min-width: 34px;
        height: 34px;
        padding: 0 8px;
        border: 0;
        border-radius: 9px;
        background: rgba(255, 255, 255, 0.05);
        color: var(--soft);
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: color 0.15s, background 0.15s;
    }
    .pager button:hover:not(:disabled):not(.current) {
        color: var(--accent);
        background: var(--accent-dim);
    }
    .pager button.current {
        color: var(--accent);
        background: var(--accent-dim);
        font-weight: 600;
        cursor: default;
    }
    .pager button:disabled {
        opacity: 0.3;
        cursor: default;
    }

    @media (max-width: 600px) {
        .blog-wrap {
            padding: 104px 0 56px;
        }
    }
</style>
