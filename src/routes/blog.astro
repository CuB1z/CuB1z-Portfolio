---
import { getLocale, t } from "i18n:astro";
import { getCollection } from "astro:content";

import { buildUrl } from "@/utils/urlUtils";
import { formatDateParts } from "@/utils/formatUtils";

import Layout from "@layouts/Layout.astro";
import InnerHeader from "@components/shared/InnerHeader.astro";

const currentLocale = getLocale();

const allPosts = await getCollection("post");
const posts = allPosts.filter(
    (post) => !post.data.locale || post.data.locale === currentLocale
);

const sortedPosts = posts.sort(
    (a, b) =>
        new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
);
---

<Layout>
    <InnerHeader />

    <section class="blog">
        <header class="page-head">
            <h1>
                {t("blog:heading")} <span class="em">{t("blog:headingEm")}</span>
            </h1>
            <p class="lede">{t("blog:lede")}</p>
        </header>

        <ul class="post-list">
            {
                sortedPosts.map((post) => (
                    <li>
                        <a class="post" href={buildUrl(`/blog/${post.slug}`)}>
                            <time class="date">
                                <span>{formatDateParts(post.data.pubDate, currentLocale).line1}</span>
                                <span>{formatDateParts(post.data.pubDate, currentLocale).line2}</span>
                            </time>
                            <div class="body">
                                <h2 class="title">{post.data.title}</h2>
                                <p class="excerpt">{post.data.description}</p>
                                {post.data.tags && (
                                    <p class="peek">
                                        {post.data.tags.map((tag, i) => (
                                            <>
                                                {i > 0 && <span class="sep">·</span>}
                                                <span class="tag">{tag}</span>
                                            </>
                                        ))}
                                    </p>
                                )}
                            </div>
                            <span class="arrow" aria-hidden="true">
                                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M7 17 17 7M9 7h8v8"/>
                                </svg>
                            </span>
                        </a>
                    </li>
                ))
            }
        </ul>
    </section>
</Layout>

<style>
    .blog {
        width: 100%;
    }

    .page-head {
        padding-bottom: 40px;
        margin-bottom: 24px;
        border-bottom: 1px solid var(--rule);
    }

    .page-head h1 {
        font-size: clamp(32px, 4.5vw, 44px);
        font-weight: 600;
        letter-spacing: -0.025em;
        color: var(--ink);
        margin-bottom: 16px;
    }

    .page-head h1 .em {
        color: var(--accent);
    }

    .lede {
        font-size: 16px;
        color: var(--ink-soft);
        max-width: 60ch;
        line-height: 1.65;
    }

    .post-list {
        list-style: none;
        display: flex;
        flex-direction: column;
    }

    .post-list li {
        border-bottom: 1px solid var(--rule);
    }

    .post {
        display: grid;
        grid-template-columns: 140px 1fr auto;
        gap: 28px;
        padding: 28px 0;
        align-items: start;
        color: var(--ink);
        text-decoration: none;
        transition: padding-left 0.3s cubic-bezier(0.2, 0.7, 0.2, 1);
    }

    .post:hover {
        padding-left: 12px;
    }

    .date {
        font-size: 12px;
        font-weight: 500;
        color: var(--ink-mute);
        letter-spacing: 0.1em;
        text-transform: uppercase;
        padding-top: 8px;
        display: flex;
        flex-direction: column;
        gap: 4px;
        line-height: 1.2;
    }

    .body {
        display: flex;
        flex-direction: column;
        gap: 12px;
        min-width: 0;
    }

    .title {
        font-size: clamp(20px, 2.4vw, 26px);
        font-weight: 600;
        color: var(--ink);
        letter-spacing: -0.02em;
        transition: color 0.2s ease;
    }

    .post:hover .title {
        color: var(--accent);
    }

    .excerpt {
        font-size: 15.5px;
        color: var(--ink-soft);
        line-height: 1.7;
        max-width: 64ch;
    }

    .peek {
        margin-top: 8px;
        font-size: 12.5px;
        color: var(--ink-mute);
    }

    .peek .tag {
        color: var(--ink-soft);
        text-decoration: underline;
        text-decoration-color: var(--rule-strong);
        text-underline-offset: 6px;
        text-decoration-thickness: 1px;
    }

    .peek .sep {
        display: inline-block;
        margin: 0 12px;
        color: var(--ink-mute);
        opacity: 0.5;
    }

    .arrow {
        color: var(--ink-mute);
        padding-top: 4px;
        display: inline-flex;
        transition: color 0.2s ease, transform 0.3s ease;
    }

    .post:hover .arrow {
        color: var(--accent);
        transform: translate(4px, -4px);
    }

    @media (max-width: 600px) {
        .post {
            grid-template-columns: 1fr auto;
            gap: 16px;
            padding: 32px 0;
        }
        .date {
            grid-column: 1 / -1;
            padding-top: 0;
        }
    }
</style>
