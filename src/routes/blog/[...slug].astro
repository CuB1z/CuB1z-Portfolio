---
import { getCollection } from "astro:content";
import { getLocale, getLocalePlaceholder, t } from "i18n:astro";

import { buildAltLangUrl, buildUrl } from "@/utils/urlUtils";
import { formatDate } from "@/utils/formatUtils";
import { socialData } from "@/constants/socialData";
import Layout from "@layouts/Layout.astro";
import Breadcrumb from "@components/shared/Breadcrumb.astro";

export async function getStaticPaths() {
    const locale = getLocalePlaceholder();
    const posts = await getCollection("post");

    return posts
        .filter((post) => (post.data.locale ?? "en") === locale)
        .map((post) => {
            const slug = post.data.slug || post.slug;
            return { params: { slug }, props: post };
        });
}

const post = Astro.props;
const { Content, headings } = await post.render();
const currentLocale = getLocale();

const toc = headings.filter((h) => h.depth === 2);
const altLangUrl = buildAltLangUrl(`/blog/${post.data.altSlug}`, currentLocale);

const authorName = "Diego Sánchez Rincón";
const siteUrl = Astro.site!.toString().replace(/\/$/, "");
const authorImage = `${siteUrl}/images/diego-sanchez.webp`;
const canonicalHref = new URL(Astro.url.pathname, Astro.site).toString();

const blogPostingLd = {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    headline: post.data.title,
    description: post.data.description,
    datePublished: post.data.pubDate.toISOString(),
    ...(post.data.updatedDate && {
        dateModified: post.data.updatedDate.toISOString(),
    }),
    inLanguage: currentLocale,
    ...(post.data.image && {
        image: new URL(post.data.image, Astro.site).toString(),
    }),
    ...(post.data.tags && { keywords: post.data.tags }),
    author: { "@type": "Person", name: authorName, url: siteUrl, image: authorImage },
    mainEntityOfPage: canonicalHref,
};
---

<Layout
    title={`${post.data.title} — Diego Sánchez Rincón`}
    description={post.data.description}
    altLangUrl={altLangUrl}
    navActive="writing"
>
    <script
        slot="head"
        type="application/ld+json"
        set:html={JSON.stringify(blogPostingLd)}
    />
    <article class="article">
        <Breadcrumb
            items={[
                { label: currentLocale === "es" ? "Inicio" : "Home", href: buildUrl("/") },
                { label: t("blog:heading"), href: buildUrl("/blog") },
                { label: post.data.title },
            ]}
        />

        <div class:list={["layout", { "has-toc": toc.length > 0 }]}>
            <div class="main">
                <header class="p-head">
                    <h1 class="p-title">{post.data.title}</h1>
                    <div class="p-meta">
                        <span class="byline">{t("blog:by")} {authorName}</span>
                        <span class="dot">·</span>
                        <time datetime={post.data.pubDate.toISOString()}>
                            {formatDate(post.data.pubDate, currentLocale)}
                        </time>
                        {
                            post.data.updatedDate && (
                                <>
                                    <span class="dot">·</span>
                                    <time datetime={post.data.updatedDate.toISOString()}>
                                        {t("blog:updated")}{" "}
                                        {formatDate(post.data.updatedDate, currentLocale)}
                                    </time>
                                </>
                            )
                        }
                    </div>
                    {
                        post.data.tags && (
                            <div class="tags p-tags">
                                {post.data.tags.map((tag) => (
                                    <span>{tag}</span>
                                ))}
                            </div>
                        )
                    }
                </header>

                {
                    post.data.image && (
                        <img class="hero-img" src={post.data.image} alt={post.data.imageAlt ?? post.data.title} loading="eager" />
                    )
                }

                <div class="post-content">
                    <Content />
                </div>

                <aside class="author-card">
                    <img
                        class="a-avatar"
                        src="/images/diego-sanchez.webp"
                        alt="Diego Sánchez Rincón"
                        width="46"
                        height="46"
                        loading="lazy"
                    />
                    <div class="a-body">
                        <span class="a-name">{authorName}</span>
                        <p class="a-bio">{t("blog:author_bio")}</p>
                        <div class="a-links">
                            <a href={socialData.github} target="_blank" rel="noopener noreferrer">GitHub</a>
                            <a href={socialData.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn</a>
                        </div>
                    </div>
                </aside>

                <div class="p-foot">
                    <a href={buildUrl("/blog")} class="back">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
                        {t("blog:back")}
                    </a>
                </div>
            </div>

            {
                toc.length > 0 && (
                    <aside class="toc">
                        <div class="toc-title">{t("blog:on_this_page")}</div>
                        <nav>
                            {toc.map((h) => (
                                <a href={`#${h.slug}`}>{h.text}</a>
                            ))}
                        </nav>
                    </aside>
                )
            }
        </div>
    </article>
</Layout>

<style>
    .article {
        position: relative;
        z-index: 1;
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 120px 32px 72px;
    }
    .back {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-size: 13.5px;
        font-weight: 600;
        color: var(--soft);
        transition: color 0.18s;
    }
    .back svg {
        width: 16px;
        height: 16px;
        transition: transform 0.18s;
    }
    .back:hover {
        color: var(--accent);
    }
    .back:hover svg {
        transform: translateX(-3px);
    }

    .layout {
        display: grid;
        grid-template-columns: 1fr;
        gap: 60px;
        align-items: start;
        margin-top: 22px;
    }
    .layout.has-toc {
        grid-template-columns: minmax(0, 1fr) 220px;
    }
    .main {
        min-width: 0;
    }

    .p-head {
        margin: 8px 0 28px;
        max-width: 780px;
    }
    .p-title {
        font-size: clamp(28px, 4vw, 42px);
        font-weight: 800;
        letter-spacing: -0.03em;
        line-height: 1.1;
        color: var(--ink);
    }
    .p-meta {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 10px 14px;
        margin-top: 18px;
        font-family: var(--font-mono);
        font-size: 11.5px;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        color: var(--mute);
    }
    .p-meta .dot {
        opacity: 0.5;
    }
    .p-meta .byline {
        color: var(--ink);
        text-transform: none;
        letter-spacing: 0.02em;
    }
    .p-tags {
        margin-top: 18px;
    }

    /* author bio card */
    .author-card {
        display: flex;
        align-items: flex-start;
        gap: 16px;
        margin-top: 56px;
        padding: 24px;
        border: 1px solid var(--rule);
        border-radius: 16px;
        background: var(--bg-card);
    }
    .a-avatar {
        flex-shrink: 0;
        width: 46px;
        height: 46px;
        border-radius: 50%;
        object-fit: cover;
        border: 1px solid var(--rule-2);
        display: block;
    }
    .a-name {
        display: block;
        font-weight: 700;
        color: var(--ink);
        font-size: 15px;
    }
    .a-bio {
        margin: 6px 0 0;
        font-size: 14px;
        line-height: 1.6;
        color: var(--soft);
        max-width: 60ch;
    }
    .a-links {
        display: flex;
        gap: 16px;
        margin-top: 12px;
        font-size: 13px;
        font-weight: 600;
    }
    .a-links a {
        color: var(--accent);
        transition: color 0.18s;
    }
    .a-links a:hover {
        color: var(--accent-bright);
    }
    .hero-img {
        width: 100%;
        aspect-ratio: 16 / 9;
        object-fit: cover;
        border-radius: 14px;
        border: 1px solid var(--rule-2);
        margin: 8px 0 40px;
        display: block;
    }

    /* TOC */
    .toc {
        position: sticky;
        top: 104px;
    }
    .toc-title {
        font-family: var(--font-mono);
        font-size: 11px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--mute);
        margin-bottom: 16px;
    }
    .toc nav {
        display: flex;
        flex-direction: column;
        border-left: 1px solid var(--rule);
    }
    .toc a {
        font-size: 13.5px;
        line-height: 1.4;
        color: var(--soft);
        padding: 7px 0 7px 16px;
        border-left: 2px solid transparent;
        margin-left: -1px;
        transition: color 0.15s, border-color 0.15s;
    }
    .toc a:hover {
        color: var(--ink);
    }
    .toc a.active {
        color: var(--accent);
        border-left-color: var(--accent);
        font-weight: 600;
    }

    .p-foot {
        margin-top: 56px;
        padding-top: 28px;
        border-top: 1px solid var(--rule);
    }

    @media (max-width: 880px) {
        .layout.has-toc {
            grid-template-columns: 1fr;
        }
        .toc {
            display: none;
        }
    }

    /* prose */
    .post-content {
        font-size: 16.5px;
        line-height: 1.8;
        color: var(--soft);
        max-width: 760px;
        overflow-wrap: break-word;
    }
    .post-content :global(p) {
        margin: 18px 0;
    }
    .post-content :global(strong) {
        color: var(--ink);
        font-weight: 600;
    }
    .post-content :global(h2),
    .post-content :global(h3),
    .post-content :global(h4) {
        color: var(--ink);
        font-weight: 700;
        letter-spacing: -0.02em;
        line-height: 1.25;
        scroll-margin-top: 96px;
    }
    .post-content :global(h2) {
        font-size: 25px;
        margin: 46px 0 4px;
    }
    .post-content :global(h3) {
        font-size: 20px;
        margin: 32px 0 4px;
    }
    .post-content :global(h4) {
        font-size: 17px;
        margin: 28px 0 4px;
    }
    .post-content :global(a) {
        color: var(--accent);
        border-bottom: 1px solid transparent;
        transition: border-color 0.18s;
    }
    .post-content :global(a:hover) {
        border-bottom-color: var(--accent);
    }
    .post-content :global(ul),
    .post-content :global(ol) {
        margin: 18px 0;
        padding-left: 24px;
        display: flex;
        flex-direction: column;
        gap: 9px;
    }
    .post-content :global(li) {
        line-height: 1.65;
    }
    .post-content :global(blockquote) {
        margin: 28px 0;
        padding: 4px 0 4px 22px;
        border-left: 2px solid var(--accent);
        color: var(--ink);
        font-size: 17px;
        line-height: 1.6;
    }
    .post-content :global(code) {
        font-family: var(--font-mono);
        font-size: 13.5px;
        background: var(--bg-card-2);
        border: 1px solid var(--rule);
        border-radius: 4px;
        padding: 2px 6px;
        color: var(--accent-bright);
    }
    .post-content :global(pre) {
        background: var(--bg-card);
        border: 1px solid var(--rule-2);
        border-radius: 12px;
        padding: 20px;
        overflow-x: auto;
        margin: 24px 0;
        font-size: 13.5px;
        line-height: 1.6;
    }
    .post-content :global(pre code) {
        background: none;
        border: none;
        padding: 0;
        color: var(--soft);
    }
    .post-content :global(img) {
        max-width: 100%;
        height: auto;
        margin: 24px 0;
        border: 1px solid var(--rule-2);
        border-radius: 12px;
    }
    .post-content :global(iframe) {
        width: 100%;
        aspect-ratio: 16 / 9;
        height: auto;
        border: 1px solid var(--rule-2);
        border-radius: 12px;
        margin: 24px 0;
    }
    .post-content :global(hr) {
        border: none;
        height: 1px;
        background: var(--rule);
        margin: 40px 0;
    }

    @media (max-width: 600px) {
        .article {
            padding: 104px 22px 56px;
        }
    }
    @media (max-width: 560px) {
        .post-content {
            font-size: 15.5px;
        }
        .post-content :global(h2) {
            font-size: 22px;
        }
    }
</style>
