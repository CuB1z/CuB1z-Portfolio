---
import { getCollection } from "astro:content";
import { getLocale, getLocalePlaceholder, t } from "i18n:astro";

import { buildAltLangUrl, buildUrl } from "@/utils/urlUtils";
import { formatDate } from "@/utils/formatUtils";

import { ArrowLeftIcon } from "@lucide/astro";
import Layout from "@layouts/Layout.astro";
import InnerHeader from "@components/shared/InnerHeader.astro";
import Button from "@/components/shared/Button.astro";

export async function getStaticPaths() {
    const locale = getLocalePlaceholder();
    const posts = await getCollection("post");

    return posts
        .filter((post) => (post.data.locale ?? "en") === locale)
        .map((post) => {
            const slug = post.data.slug || post.slug;

            return {
                params: {
                    slug: slug,
                },
                props: post,
            };
        });
}

const post = Astro.props;
const { Content } = await post.render();
const currentLocale = getLocale();
---

<Layout
    altLangUrl={buildAltLangUrl(`/blog/${post.data.altSlug}`, currentLocale)}
>
    <InnerHeader
        backUrl={buildUrl("/blog")}
        altLangUrl={buildAltLangUrl(
            `/blog/${post.data.altSlug}`,
            currentLocale,
        )}
    />

    <main class="post-container">
        <article class="post-article">
            {
                post.data.image && (
                    <img
                        src={post.data.image}
                        alt={post.data.title}
                        class="post-hero-image"
                    />
                )
            }

            <header class="post-header">
                <h1 class="post-title-main">
                    {post.data.title}
                </h1>

                <div class="post-meta">
                    <time class="post-date-main">
                        {formatDate(post.data.pubDate, currentLocale)}
                    </time>

                    {
                        post.data.tags && (
                            <p class="post-tags-main">
                                {post.data.tags.map((tag, i) => (
                                    <>
                                        {i > 0 && <span class="sep">·</span>}
                                        <span class="tag">{tag}</span>
                                    </>
                                ))}
                            </p>
                        )
                    }
                </div>
            </header>

            <div class="post-content">
                <Content />
            </div>
        </article>

        <div class="post-actions">
            <Button
                variant="primary"
                href={buildUrl("/blog")}
                title={t("blog:goBack")}
                ><ArrowLeftIcon size={16} />{t("blog:goBack")}
            </Button>
        </div>

        <style>
            .post-container {
                width: 100%;
            }

            .post-article {
                margin-bottom: 48px;
            }

            .post-hero-image {
                width: 100%;
                max-width: 100%;
                height: 300px;
                object-fit: cover;
                margin-bottom: 40px;
                border: 1px solid var(--rule);
                border-radius: 8px;
                display: block;
            }

            .post-header {
                margin-bottom: 48px;
                padding-bottom: 28px;
                border-bottom: 1px solid var(--rule);
            }

            .post-title-main {
                font-size: clamp(28px, 4vw, 40px);
                font-weight: 600;
                line-height: 1.15;
                letter-spacing: -0.025em;
                color: var(--ink);
                margin: 0 0 20px 0;
            }

            .post-meta {
                display: flex;
                flex-wrap: wrap;
                align-items: center;
                gap: 16px 22px;
            }

            .post-date-main {
                color: var(--ink-mute);
                font-size: 12px;
                font-weight: 500;
                letter-spacing: 0.1em;
                text-transform: uppercase;
            }

            .post-tags-main {
                font-size: 12.5px;
                color: var(--ink-mute);
            }

            .post-tags-main .tag {
                color: var(--ink-soft);
                text-decoration: underline;
                text-decoration-color: var(--rule-strong);
                text-underline-offset: 6px;
                text-decoration-thickness: 1px;
            }

            .post-tags-main .sep {
                display: inline-block;
                margin: 0 12px;
                color: var(--ink-mute);
                opacity: 0.5;
            }

            .post-content {
                color: var(--ink-soft);
                line-height: 1.75;
                font-size: 16.5px;
                max-width: 100%;
                overflow-wrap: break-word;
            }

            .post-content :global(h1),
            .post-content :global(h2),
            .post-content :global(h3),
            .post-content :global(h4),
            .post-content :global(h5),
            .post-content :global(h6) {
                color: var(--ink);
                margin: 36px 0 14px 0;
                font-weight: 600;
                letter-spacing: -0.02em;
                line-height: 1.3;
            }

            .post-content :global(h1) {
                font-size: 28px;
            }
            .post-content :global(h2) {
                font-size: 24px;
            }
            .post-content :global(h3) {
                font-size: 20px;
            }
            .post-content :global(h4) {
                font-size: 17px;
            }

            .post-content :global(p) {
                margin: 16px 0;
            }

            .post-content :global(a) {
                color: var(--accent);
                border-bottom: 1px solid transparent;
                transition: border-color 0.2s ease;
            }

            .post-content :global(a:hover) {
                border-bottom-color: var(--accent);
            }

            .post-content :global(ul),
            .post-content :global(ol) {
                margin: 16px 0;
                padding-left: 24px;
            }

            .post-content :global(li) {
                margin: 6px 0;
            }

            .post-content :global(blockquote) {
                margin: 28px 0;
                padding: 8px 0 8px 20px;
                border-left: 2px solid var(--accent);
                color: var(--ink);
                font-size: 16px;
                line-height: 1.65;
            }

            .post-content :global(code) {
                background-color: var(--paper-2);
                padding: 2px 6px;
                font-family: var(--font-mono);
                font-size: 13.5px;
                border: 1px solid var(--rule);
                border-radius: 3px;
            }

            .post-content :global(pre) {
                background-color: var(--paper-2);
                padding: 20px;
                overflow-x: auto;
                margin: 24px 0;
                border: 1px solid var(--rule);
                border-radius: 8px;
                max-width: 100%;
                font-size: 13.5px;
                line-height: 1.55;
            }

            .post-content :global(pre code) {
                background: none;
                padding: 0;
                border: none;
            }

            .post-content :global(img) {
                max-width: 100%;
                height: auto;
                margin: 24px 0;
                border: 1px solid var(--rule);
                border-radius: 8px;
            }

            .post-content :global(hr) {
                border: none;
                height: 1px;
                background-color: var(--rule);
                margin: 36px 0;
            }

            .post-actions {
                width: 100%;
                display: flex;
                justify-content: center;
                align-items: center;
                padding-top: 32px;
                border-top: 1px solid var(--rule);
            }

            @media (max-width: 768px) {
                .post-hero-image {
                    height: 200px;
                    margin-bottom: 28px;
                }

                .post-header {
                    margin-bottom: 32px;
                    padding-bottom: 20px;
                }

                .post-content {
                    font-size: 15.5px;
                }

                .post-content :global(h1) {
                    font-size: 22px;
                }
                .post-content :global(h2) {
                    font-size: 20px;
                }
                .post-content :global(h3) {
                    font-size: 18px;
                }
                .post-content :global(h4) {
                    font-size: 16px;
                }

                .post-content :global(pre) {
                    padding: 16px;
                    font-size: 12.5px;
                }
            }
        </style>
    </main>
</Layout>
