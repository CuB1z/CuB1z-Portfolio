---
import Layout from "@layouts/Layout.astro";
import { t } from "i18n:astro";
import { buildUrl } from "@utils/urlUtils";
---

<Layout>
    <section class="notfound">
        <h1 class="title">
            <span class="num">404</span>
            <span class="name">
                {t("404:heading")} <span class="em">{t("404:headingEm")}</span>
            </span>
        </h1>

        <p class="lede">{t("404:description")}</p>

        <a class="back" href={buildUrl("/")}>
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                <path d="M19 12H5M12 19l-7-7 7-7" />
            </svg>
            <span>{t("404:button")}</span>
        </a>
    </section>
</Layout>

<style>
    .notfound {
        min-height: 100dvh;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        text-align: center;
        gap: 24px;
        padding: 0 32px;
        max-width: var(--max-width);
        margin: 0 auto;
        width: 100%;
    }

    .title {
        display: inline-flex;
        align-items: baseline;
        justify-content: center;
        gap: 20px;
        font-size: clamp(36px, 5vw, 56px);
        font-weight: 600;
        color: var(--ink);
        letter-spacing: -0.025em;
        line-height: 1.05;
        flex-wrap: wrap;
    }

    .title .num {
        color: var(--mute);
        flex-shrink: 0;
    }

    .title .em {
        color: var(--accent);
    }

    .lede {
        font-size: 16px;
        color: var(--soft);
        line-height: 1.65;
        max-width: 56ch;
    }

    .back {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        margin-top: 16px;
        font-size: 14px;
        font-weight: 500;
        color: var(--ink);
        transition: color 0.2s ease, gap 0.2s ease;
    }

    .back svg {
        transition: transform 0.2s ease;
    }

    .back:hover {
        color: var(--accent);
        gap: 14px;
    }

    .back:hover svg {
        transform: translateX(-3px);
    }

    @media (max-width: 600px) {
        .notfound {
            padding: 0 24px;
        }
    }
</style>
