---
import { t, getLocale } from "i18n:astro";

import { ClientRouter } from "astro:transitions";

import Nav from "@components/shared/Nav.astro";
import Footer from "@components/shared/Footer.astro";
import { socialData } from "@/constants/socialData";

interface Props {
    title?: string;
    description?: string;
    altLangUrl?: string;
    navActive?: string;
    home?: boolean;
}

const {
    title,
    description,
    altLangUrl,
    navActive,
    home = false,
} = Astro.props as Props;

const locale = getLocale();

const pageTitle = title ?? t("title");
const pageDescription = description ?? t("description");

const currentPath = Astro.url.pathname;
const isEs = currentPath.startsWith("/es");
const cleanPath = isEs ? currentPath.replace(/^\/es/, "") : currentPath;

const enUrl =
    locale === "es" && altLangUrl
        ? new URL(altLangUrl, Astro.site)
        : new URL(cleanPath, Astro.site);
const esUrl =
    locale === "en" && altLangUrl
        ? new URL(altLangUrl, Astro.site)
        : new URL(`/es${cleanPath === "/" ? "/" : cleanPath}`, Astro.site);

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);

const siteUrl = Astro.site!.toString().replace(/\/$/, "");
const email = socialData.email.replace(/^mailto:/, "");

const jobTitle = t("schema.jobTitle");
const knowsAbout = t("schema.knowsAbout", { returnObjects: true }) as string[];

const personLd = {
    "@context": "https://schema.org",
    "@type": "Person",
    name: "Diego Sánchez Rincón",
    alternateName: ["Diego Sánchez", "CuB1z"],
    givenName: "Diego",
    familyName: "Sánchez Rincón",
    url: siteUrl,
    image: `${siteUrl}/images/diego-sanchez.webp`,
    jobTitle,
    description: pageDescription,
    worksFor: { "@type": "Organization", name: "Génexys Technology" },
    alumniOf: {
        "@type": "CollegeOrUniversity",
        name: "Universidad Rey Juan Carlos",
    },
    address: {
        "@type": "PostalAddress",
        addressLocality: "Madrid",
        addressCountry: "ES",
    },
    email,
    knowsAbout,
    sameAs: [socialData.github, socialData.linkedin],
};

const websiteLd = {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: `Diego Sánchez Rincón · ${jobTitle}`,
    alternateName: ["Diego Sánchez", "CuB1z"],
    url: siteUrl,
    description: pageDescription,
    inLanguage: locale,
    author: { "@type": "Person", name: "Diego Sánchez Rincón", url: siteUrl },
};
---

<html lang={locale}>
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>{pageTitle}</title>
        <meta name="description" content={pageDescription} />

        <link rel="canonical" href={canonicalUrl} />
        <link rel="alternate" hreflang="en" href={enUrl} />
        <link rel="alternate" hreflang="es" href={esUrl} />
        <link rel="alternate" hreflang="x-default" href={enUrl} />

        <meta property="og:type" content="website" />
        <meta property="og:url" content={Astro.url} />
        <meta property="og:title" content={pageTitle} />
        <meta property="og:description" content={pageDescription} />
        <meta property="og:image" content={new URL("/og-image.png", Astro.site)} />

        <meta property="twitter:card" content="summary_large_image" />
        <meta property="twitter:url" content={Astro.url} />
        <meta property="twitter:title" content={pageTitle} />
        <meta property="twitter:description" content={pageDescription} />
        <meta property="twitter:image" content={new URL("/og-image.png", Astro.site)} />

        <link rel="icon" href="/favicon.svg" />

        <script
            type="application/ld+json"
            set:html={JSON.stringify(websiteLd)}
        />
        {
            home && (
                <script
                    type="application/ld+json"
                    set:html={JSON.stringify(personLd)}
                />
            )
        }
        <slot name="head" />

        <link
            rel="preload"
            href="/fonts/geist.woff2"
            as="font"
            type="font/woff2"
            crossorigin
        />

        <ClientRouter />
    </head>
    <body>
        <Nav home={home} active={navActive} altLangUrl={altLangUrl} />
        <slot />
        <Footer />

        <script>
            // Active-section + table-of-contents highlighting.
            // Re-runs on every navigation so it keeps working with view transitions.
            let navObserver: IntersectionObserver | undefined;
            let tocObserver: IntersectionObserver | undefined;

            function initNav() {
                navObserver?.disconnect();
                const links = Array.from(
                    document.querySelectorAll<HTMLAnchorElement>(".nav-links a")
                );
                const sections = Array.from(document.querySelectorAll("section[id]"));
                if (!links.length || !sections.length) return;
                const setActive = (id: string) =>
                    links.forEach((a) =>
                        a.classList.toggle("active", a.getAttribute("href") === "#" + id)
                    );
                navObserver = new IntersectionObserver(
                    (entries) => {
                        entries.forEach((e) => {
                            if (e.isIntersecting) setActive((e.target as HTMLElement).id);
                        });
                    },
                    { rootMargin: "-45% 0px -50% 0px", threshold: 0 }
                );
                sections.forEach((s) => navObserver!.observe(s));
            }

            function initToc() {
                tocObserver?.disconnect();
                const links = Array.from(
                    document.querySelectorAll<HTMLAnchorElement>(".toc a")
                );
                const headings = Array.from(
                    document.querySelectorAll<HTMLElement>(".post-content h2[id]")
                );
                if (!links.length || !headings.length) return;
                const setActive = (id: string) =>
                    links.forEach((a) =>
                        a.classList.toggle("active", a.getAttribute("href") === "#" + id)
                    );
                tocObserver = new IntersectionObserver(
                    (entries) => {
                        entries.forEach((e) => {
                            if (e.isIntersecting) setActive((e.target as HTMLElement).id);
                        });
                    },
                    { rootMargin: "-96px 0px -65% 0px", threshold: 0 }
                );
                headings.forEach((h) => tocObserver!.observe(h));
                if (headings[0]) setActive(headings[0].id);
            }

            function initPager() {
                const list = document.querySelector<HTMLElement>(".list");
                const pager = document.querySelector<HTMLElement>(".pager");
                if (!list || !pager) return;
                const posts = Array.from(list.querySelectorAll<HTMLElement>(".post"));
                const numBtns = Array.from(
                    pager.querySelectorAll<HTMLButtonElement>(".pg-num")
                );
                const prev = pager.querySelector<HTMLButtonElement>('[data-rel="prev"]');
                const next = pager.querySelector<HTMLButtonElement>('[data-rel="next"]');
                if (!numBtns.length || !prev || !next) return;
                const PER = 4;
                const pages = numBtns.length;
                let current = 1;
                const go = (n: number, scroll = false) => {
                    current = Math.min(Math.max(1, n), pages);
                    posts.forEach((p, idx) => {
                        p.style.display =
                            Math.floor(idx / PER) + 1 === current ? "" : "none";
                    });
                    numBtns.forEach((b, i) =>
                        b.classList.toggle("current", i + 1 === current)
                    );
                    prev.disabled = current === 1;
                    next.disabled = current === pages;
                    if (scroll) {
                        const head = document.querySelector<HTMLElement>(".page-head");
                        const y = head
                            ? head.getBoundingClientRect().top + window.scrollY - 90
                            : 0;
                        window.scrollTo({ top: Math.max(0, y), behavior: "smooth" });
                    }
                };
                numBtns.forEach((b, i) => (b.onclick = () => go(i + 1, true)));
                prev.onclick = () => go(current - 1, true);
                next.onclick = () => go(current + 1, true);
                pager.hidden = false;
                go(1);
            }

            document.addEventListener("astro:page-load", () => {
                initNav();
                initToc();
                initPager();
            });
        </script>
    </body>
</html>

<style is:global>
    @font-face {
        font-family: "Geist";
        font-style: normal;
        font-weight: 100 900;
        font-display: swap;
        src: url("/fonts/geist.woff2") format("woff2");
    }
    @font-face {
        font-family: "Geist Mono";
        font-style: normal;
        font-weight: 100 900;
        font-display: swap;
        src: url("/fonts/geist-mono.woff2") format("woff2");
    }

    *,
    *::before,
    *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        scrollbar-width: thin;
        scrollbar-color: var(--mute) transparent;
        -webkit-tap-highlight-color: transparent;
    }

    :root {
        --font-sans: "Geist", system-ui, -apple-system, "Segoe UI", sans-serif;
        --font-mono: "Geist Mono", ui-monospace, "SFMono-Regular", Menlo, monospace;

        --bg: #0a0c10;
        --bg-card: #10141a;
        --bg-card-2: #141922;
        --ink: #f3f7fb;
        --soft: #a7b1bd;
        --mute: #5b6675;
        --rule: #1a1f27;
        --rule-2: #272f3a;
        --accent: #73b3d8;
        --accent-bright: #9ccde9;
        --accent-dim: rgba(115, 179, 216, 0.14);
        --accent-glow: rgba(115, 179, 216, 0.1);

        --max-width: 1080px;
    }

    html {
        scroll-behavior: smooth;
    }

    body {
        font-family: var(--font-sans);
        background: var(--bg);
        color: var(--soft);
        font-size: 16px;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        overflow-x: hidden;
        min-height: 100vh;
    }

    body::before {
        content: "";
        position: fixed;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        background: radial-gradient(
            120% 70% at 50% -10%,
            var(--accent-glow),
            transparent 55%
        );
    }

    a {
        text-decoration: none;
        color: inherit;
    }

    ::selection {
        background: var(--accent);
        color: var(--bg);
    }

    h1,
    h2,
    h3,
    h4,
    h5,
    h6 {
        color: var(--ink);
        letter-spacing: -0.02em;
        line-height: 1.15;
        font-weight: 700;
    }

    /* shared container */
    .shell {
        position: relative;
        z-index: 1;
        width: 100%;
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 0 32px;
    }

    /* home section scaffolding */
    .section {
        padding: 64px 0;
        scroll-margin-top: 96px;
    }

    .sec-head {
        display: flex;
        align-items: baseline;
        gap: 16px;
        margin-bottom: 40px;
    }
    .sec-head .num {
        font-family: var(--font-mono);
        font-size: 13px;
        color: var(--accent);
        font-weight: 600;
    }
    .sec-head h2 {
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--ink);
    }
    .sec-head .line {
        flex: 1;
        height: 1px;
        background: var(--rule);
    }

    /* shared tech tag chips */
    .tags {
        display: flex;
        flex-wrap: wrap;
        gap: 7px;
    }
    .tags span {
        font-family: var(--font-mono);
        font-size: 11.5px;
        color: var(--soft);
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid var(--rule);
        border-radius: 7px;
        padding: 4px 9px;
    }

    @media (max-width: 600px) {
        .shell {
            padding: 0 22px;
        }
        .section {
            padding: 52px 0;
        }
    }
</style>
