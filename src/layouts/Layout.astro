---
import { t, getLocale } from "i18n:astro";

import Footer from "@components/shared/Footer.astro";
import Header from "@components/shared/Header.astro";
import { ClientRouter } from "astro:transitions";

interface Props {
    extended?: boolean;
    single?: boolean;
    altLangUrl?: string;
    showHeader?: boolean;
}

const { extended, single, altLangUrl, showHeader = false } = Astro.props as Props;

const locale = getLocale();

const currentPath = Astro.url.pathname;
const isEs = currentPath.startsWith("/es");
const cleanPath = isEs ? currentPath.replace(/^\/es/, "") : currentPath;

const enUrl =
    locale === "es" && altLangUrl
        ? new URL(altLangUrl, Astro.site)
        : new URL(cleanPath, Astro.site);
const esUrl =
    locale === "en" && altLangUrl
        ? new URL(altLangUrl, Astro.site)
        : new URL(`/es${cleanPath === "/" ? "" : cleanPath}`, Astro.site);

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
---

<html lang={locale} data-theme="dark">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>{t("title")}</title>
        <meta name="description" content={t("description")} />

        <link rel="canonical" href={canonicalUrl} />
        <link rel="alternate" hreflang="en" href={enUrl} />
        <link rel="alternate" hreflang="es" href={esUrl} />
        <link rel="alternate" hreflang="x-default" href={enUrl} />

        <meta property="og:type" content="website" />
        <meta property="og:url" content={Astro.url} />
        <meta property="og:title" content={t("title")} />
        <meta property="og:description" content={t("description")} />
        <meta property="og:image" content={new URL("/og-image.png", Astro.site)} />

        <meta property="twitter:card" content="summary_large_image" />
        <meta property="twitter:url" content={Astro.url} />
        <meta property="twitter:title" content={t("title")} />
        <meta property="twitter:description" content={t("description")} />
        <meta property="twitter:image" content={new URL("/og-image.png", Astro.site)} />

        <link rel="icon" href="/favicon.svg" />

        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&family=Geist+Mono:wght@400;500&display=swap" rel="stylesheet">

        <ClientRouter />
    </head>
    <body>
        {showHeader && !single && <Header altLangUrl={altLangUrl} />}
        <div class={"wrapper" + (extended ? " extended" : "")}>
            <main class="content">
                <slot />
            </main>
            {!single && <Footer />}
        </div>
    </body>
</html>

<style is:global>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        scrollbar-width: thin;
        scrollbar-color: var(--ink-mute) transparent;

        -webkit-tap-highlight-color: transparent;
        -webkit-touch-callout: none;
        user-select: text;

        &::selection {
            background: var(--accent);
            color: var(--paper);
        }
    }

    a {
        text-decoration: none !important;
    }

    :root {
        --font-sans: "Geist", system-ui, -apple-system, "Segoe UI", sans-serif;
        --font-mono: "Geist Mono", ui-monospace, "SFMono-Regular", Menlo, monospace;

        --accent: #73B3D8;
        --max-width: 1000px;
        --max-width-extended: 1000px;
    }

    [data-theme="dark"] {
        --paper: #16191D;
        --paper-2: #14171C;
        --ink: #ECEEF1;
        --ink-soft: #B6BCC4;
        --ink-mute: #6B7280;
        --rule: #21262D;
        --rule-strong: #2A3038;
        --accent-soft: #73B3D826;
    }

    [data-theme="light"] {
        --paper: #FAFAF7;
        --paper-2: #F2F2EE;
        --ink: #14171C;
        --ink-soft: #3A4049;
        --ink-mute: #8A8F98;
        --rule: #E4E2DC;
        --rule-strong: #CFCDC7;
        --accent-soft: #73B3D81F;
    }

    /* Legacy variable aliases — keep until all components are migrated */
    :root {
        --bg-primary: var(--paper);
        --bg-secondary: var(--paper-2);
        --border-color: var(--rule);
        --text-primary: var(--ink);
        --text-secondary: var(--ink-soft);
        --text-muted: var(--ink-mute);
        --accent-light: var(--ink-soft);
        --accent-alpha: var(--accent-soft);
        --green-color: #3bb27c;
    }

    html, body {
        background: var(--paper);
        color: var(--ink-soft);
        font-family: var(--font-sans);
        font-size: 16px;
        line-height: 1.55;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
    }

    body {
        display: flex;
        flex-direction: column;
        align-items: center;
        min-height: 100vh;
    }

    h1, h2, h3, h4, h5, h6 {
        color: var(--ink);
        font-weight: 600;
        letter-spacing: -0.02em;
        line-height: 1.2;
    }

    a, a:visited {
        color: var(--ink);
        transition: color 0.2s ease;
    }

    a:hover, a:focus {
        color: var(--accent);
    }

    .wrapper {
        width: 100%;
        max-width: var(--max-width);
        flex: 1;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        padding: 0 24px 64px;

        &.extended {
            max-width: var(--max-width-extended);
        }
    }

    .content {
        width: 100%;
        min-height: 80dvh;
        display: flex;
        flex-direction: column;
    }

    iframe {
        width: 100%;
        height: auto;
        aspect-ratio: 16 / 9;
        border: 1px solid var(--rule);
    }

    @media (max-width: 768px) {
        .wrapper {
            padding: 0 20px 48px;
        }
    }
</style>
